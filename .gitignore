# Third-party agent skills (installed locally via `npx skills add ...`).
# These are NOT bundled in this repo — end users install them themselves
# alongside lark-cli as part of their own environment setup.
.agents/
skills/
skills-lock.json
.claude/

# Logs
*.log

# Test inputs/outputs (local scratch)
scratch/
tmp/
*.inlined.html
*.flat.html
*.wechat.html
output/

# Internal-only test samples — drive mode 1/2/3/4 testing locally but
# may carry proprietary / pre-publication content (PRDs, market reports,
# unreleased articles). Synthetic test fixtures (probe/) and plan-demo
# JSON schemas stay public as testing infrastructure.
samples/*
!samples/probe/
!samples/bench-plan-*.json
!samples/README.md
!samples/.gitkeep
